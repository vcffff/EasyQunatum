# Fixed Quantum Particle Model
o QuantumParticle

# Вершины пирамиды
v 0.0 0.0 1.0         # Вершина (верх)
v 1.0 1.0 -1.0        # Основание
v -1.0 1.0 -1.0
v -1.0 -1.0 -1.0
v 1.0 -1.0 -1.0

# Нормали (фиктивные — для рендера)
vn 0.0 0.0 1.0

# Грани (4 стороны пирамиды)
f 1//1 2//1 3//1
f 1//1 3//1 4//1
f 1//1 4//1 5//1
f 1//1 5//1 2//1

# Основание (необязательно, но можно)
f 2//1 3//1 4//1
f 2//1 4//1 5//1
